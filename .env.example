POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lake_catalog

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
LAKEHOUSE_BUCKET=lakehouse

# Must be at least 32 characters
JWT_SECRET=supersecretkey_change_in_production

# Admin API key for platform operator endpoints (e.g., retrieving service account credentials)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change_this_to_a_secure_random_key

# Log level: 'info' (default) or 'debug' (verbose logging for troubleshooting)
# Set to 'debug' to enable detailed logging of DuckDB session creation, MinIO credentials, and DuckLake operations
LOG_LEVEL=info
